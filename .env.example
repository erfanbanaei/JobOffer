DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
# Required from Iran (Telegram is blocked). Point this at your local V2Ray/Xray/Clash
# SOCKS5 or HTTP proxy. Use host.docker.internal instead of 127.0.0.1 when running via docker compose.
TELEGRAM_PROXY_URL=socks5://host.docker.internal:10808

POSTGRES_DB=jobbot
POSTGRES_USER=jobbot
POSTGRES_PASSWORD=jobbot
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
