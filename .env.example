DJANGO_SECRET_KEY=change-me
# Set to False on a real server (DEBUG=True leaks stack traces to visitors)
DJANGO_DEBUG=True
# Add your real domain here once deployed, e.g. localhost,127.0.0.1,yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token

# Your server's domain name, no scheme/path (used by the Caddy reverse proxy
# to request an automatic Let's Encrypt certificate). e.g. yourdomain.com
DOMAIN=

# Public HTTPS URL where the Mini App is served, e.g. https://yourdomain.com/app/
# Must be a real https:// URL (Telegram rejects http:// for WebApp buttons).
MINI_APP_URL=

POSTGRES_DB=jobbot
POSTGRES_USER=jobbot
POSTGRES_PASSWORD=jobbot
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
